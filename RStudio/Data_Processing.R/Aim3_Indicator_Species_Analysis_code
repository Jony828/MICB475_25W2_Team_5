### ISA

library(phyloseq)
library(tidyverse)
library(indicspecies)
library(dplyr)

# Load separate phyloseqs
load("PD_phy.RData")
load("GC_phy.RData")

### Run PD analysis
PD_meta <- data.frame(sample_data(PD_phy))

# Define groups
PD_meta$Group_clean <- case_when(
  PD_meta$Disease == "PD" ~ "PD",
  PD_meta$Disease == "Control" ~ "PD_control"
)

# Convert to factor
PD_meta$Group_clean <- as.factor(PD_meta$Group_clean)

# Put cleaned group column back into PD_phy
sample_data(PD_phy)$Group_clean <- PD_meta$Group_clean

#### Glom to Genus ####
PD_phy_genus <- tax_glom(PD_phy, "Genus", NArm = FALSE)

#### Convert counts to relative abundance ####
PD_phy_genus_RA <- transform_sample_counts(
  PD_phy_genus,
  function(x) x / sum(x)
)

#### Filter rare taxa (present in at least 10% of samples) ####
PD_phy_genus_RA <- filter_taxa(
  PD_phy_genus_RA,
  function(x) sum(x > 0) > 0.1 * length(x),
  TRUE
)

#### Make sure Group_clean is a factor
sample_data(PD_phy_genus_RA)$Group_clean <- as.factor(sample_data(PD_phy_genus_RA)$Group_clean)

#### Run Indicator Species Analysis ####
PD_isa_result <- multipatt(
  t(otu_table(PD_phy_genus_RA)),
  cluster = sample_data(PD_phy_genus_RA)$Group_clean,
  func = "IndVal.g",
  control = how(nperm = 999)
)

#### Prepare taxonomy table for joining
PD_tax_df <- tax_table(PD_phy_genus_RA) %>%
  as.data.frame() %>%
  rownames_to_column(var = "ASV")

#### Extract significant indicator taxa (p < 0.05)
PD_isa_significant <- PD_isa_result$sign %>%
  rownames_to_column(var = "ASV") %>%
  left_join(PD_tax_df, by = "ASV") %>%
  filter(p.value < 0.05)

#### Strong indicators only (stat > 0.8)
PD_isa_strong <- PD_isa_best %>%
  filter(stat > 0.8)


### GC ISA

# Get metadata from GC_phy
GC_meta <- data.frame(sample_data(GC_phy))

# Keep only GC cases and HC controls
GC_meta_filtered <- GC_meta %>%
  filter(Disease %in% c("GC", "HC"))

# Define groups
GC_meta_filtered$Group_clean <- case_when(
  GC_meta_filtered$Disease == "GC" ~ "GC",
  GC_meta_filtered$Disease == "HC" ~ "GC_control"
)

# Convert to factor
GC_meta_filtered$Group_clean <- as.factor(GC_meta_filtered$Group_clean)

# Subset phyloseq object to keep only these samples
samples_to_keep <- rownames(GC_meta_filtered)
GC_phy <- prune_samples(samples_to_keep, GC_phy)

# Put cleaned group column back into GC_phy
sample_data(GC_phy)$Group_clean <- GC_meta_filtered$Group_clean

# Glom to Genus
GC_phy_genus <- tax_glom(GC_phy, "Genus", NArm = FALSE)

# Convert counts to relative abundance
GC_phy_genus_RA <- transform_sample_counts(
  GC_phy_genus,
  function(x) x / sum(x)
)

# Filter rare taxa (present in at least 10% of samples)
GC_phy_genus_RA <- filter_taxa(
  GC_phy_genus_RA,
  function(x) sum(x > 0) > 0.1 * length(x),
  TRUE
)

# Ensure Group_clean is factor
sample_data(GC_phy_genus_RA)$Group_clean <- as.factor(sample_data(GC_phy_genus_RA)$Group_clean)

# Run Indicator Species Analysis
GC_isa_result <- multipatt(
  t(otu_table(GC_phy_genus_RA)),
  cluster = sample_data(GC_phy_genus_RA)$Group_clean,
  func = "IndVal.g",
  control = how(nperm = 999)
)

# Prepare taxonomy table
GC_tax_df <- tax_table(GC_phy_genus_RA) %>%
  as.data.frame() %>%
  rownames_to_column(var = "ASV")

# Extract significant indicator taxa (p < 0.05)
GC_isa_significant <- GC_isa_result$sign %>%
  rownames_to_column(var = "ASV") %>%
  left_join(GC_tax_df, by = "ASV") %>%
  filter(p.value < 0.05)

# Strong indicators only (stat > 0.8)
GC_isa_strong <- GC_isa_best %>%
  filter(stat > 0.8)

# View results
View(GC_isa_best)
View(GC_isa_strong)
