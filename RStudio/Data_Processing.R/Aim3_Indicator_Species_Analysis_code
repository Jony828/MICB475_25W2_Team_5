library(phyloseq)
library(tidyverse)
library(indicspecies)
library(dplyr)

#### Load phyloseq object ####

load("~/Desktop/MICB475_R/Project/new/GC_PD_phyloseq(no_tree).RData")

meta <- data.frame(sample_data(GC_PD_phy))

# Filter metadata to remove other GC stages

meta_filtered <- meta %>%
  dplyr::filter(
    Disease %in% c("PD", "Control", "GC", "HC")
  )

# Rename column groups
meta_filtered$Group_clean <- dplyr::case_when(
  meta_filtered$Dataset == "PD" & meta_filtered$Disease == "PD" ~ "PD",
  meta_filtered$Dataset == "PD" & meta_filtered$Disease == "Control" ~ "PD_control",
  
  meta_filtered$Dataset == "GC" & meta_filtered$Disease == "GC" ~ "GC",
  meta_filtered$Dataset == "GC" & meta_filtered$Disease == "HC" ~ "GC_control"
)

# Make the Group_clean column into a categorical variable (factor)
meta_filtered$Group_clean <- as.factor(meta_filtered$Group_clean)

# Check how many samples are in each group
table(meta_filtered$Group_clean)


# Subset the phyloseq and put cleaned group column back to the phyloseq object

samples_to_keep <- rownames(meta_filtered)

physeq_filtered <- prune_samples(samples_to_keep, GC_PD_phy)

sample_data(physeq_filtered)$Group_clean <- meta_filtered$Group_clean
table(sample_data(physeq_filtered)$Group_clean)

all(rownames(meta_filtered) == sample_names(physeq_filtered))

sample_data(physeq_filtered) <- phyloseq::sample_data(meta_filtered)
table(sample_data(physeq_filtered)$Group_clean)


#### Glom to genus ####
physeq_genus <- tax_glom(physeq_filtered, "Genus", NArm = FALSE)

#### Convert counts to relative abundance ####
physeq_genus_RA <- transform_sample_counts(
  physeq_genus,
  function(x) x / sum(x)
)

#### Filter rare taxa (present in at least 10% of samples) ####
physeq_genus_RA <- filter_taxa(
  physeq_genus_RA,
  function(x) sum(x > 0) > 0.1 * length(x),
  TRUE
)

#### Make sure the grouping column is a factor ####
sample_data(physeq_genus_RA)$Group_clean <- 
  as.factor(sample_data(physeq_genus_RA)$Group_clean)

#### Run Indicator Species Analysis ####
isa_result <- multipatt(
  t(otu_table(physeq_genus_RA)),
  cluster = sample_data(physeq_genus_RA)$Group_clean,
  func = "IndVal.g",
  control = how(nperm = 999)
)

#### Prepare taxonomy table for joining ####
tax_df <- tax_table(physeq_genus_RA) %>%
  as.data.frame() %>%
  rownames_to_column(var = "ASV")

#### Extract significant indicator taxa (p < 0.05) ####
isa_significant <- isa_result$sign %>%
  rownames_to_column(var = "ASV") %>%
  left_join(tax_df, by = "ASV") %>%
  filter(p.value < 0.05)

#### Strongest association per ASV ####
isa_best <- isa_significant %>%
  group_by(ASV) %>%
  slice_max(stat, n = 1) %>%
  ungroup()

#### Strong indicators only (stat > 0.7) ####
isa_strong <- isa_best %>%
  filter(stat > 0.7)

#### View results ####
View(isa_best)     
View(isa_strong)
